/**
 * POST /api/beatrice-update-draft
 * Header: X-Internal-Secret
 * Body: { draftId, subject?, bodyHtml?, signedHtml?, toRecipient?, ccRecipients? }
 *
 * Mise à jour partielle d'un draft Béatrice (édition par Yves dans le dashboard).
 * Conserve le statut pending_yves_approval pour qu'Yves puisse approuver après.
 */

import {
  createAuditLog,
  getDoc,
  getFirestoreToken,
  jsonResponse,
  loadServiceAccount,
  patchDoc,
} from "./_camille-shared.mjs";

const COLLECTION_DRAFTS = "beatriceDrafts";

const ALLOWED_FIELDS = new Set([
  "subject",
  "bodyHtml",
  "signedHtml",
  "toRecipient",
  "ccRecipients",
  "internalNoteForYves",
]);

export default async function handler(req) {
  if (req.method !== "POST") {
    return jsonResponse({ error: "Method not allowed" }, 405);
  }
  const secret = req.headers.get("x-internal-secret");
  if (!process.env.INTERNAL_SECRET || secret !== process.env.INTERNAL_SECRET) {
    return jsonResponse({ error: "Unauthorized" }, 401);
  }

  let body;
  try {
    body = await req.json();
  } catch {
    return jsonResponse({ error: "Invalid JSON" }, 400);
  }

  const draftId = body.draftId;
  if (!draftId) return jsonResponse({ error: "draftId required" }, 400);

  // Construit le patch en filtrant les champs autorisés
  const patch = {};
  for (const [k, v] of Object.entries(body)) {
    if (k === "draftId") continue;
    if (ALLOWED_FIELDS.has(k)) patch[k] = v;
  }
  if (Object.keys(patch).length === 0) {
    return jsonResponse({ error: "Aucun champ à mettre à jour" }, 400);
  }
  patch.lastModifiedAt = new Date();
  patch.lastModifiedBy = "Yves Barrette (dashboard)";

  try {
    const sa = loadServiceAccount();
    const projectId = sa.project_id;
    const fsToken = await getFirestoreToken(sa);

    const existing = await getDoc(
      projectId,
      fsToken,
      COLLECTION_DRAFTS,
      draftId
    );
    if (!existing) {
      return jsonResponse({ error: "Draft introuvable" }, 404);
    }
    if (existing.status === "sent") {
      return jsonResponse(
        { error: "Déjà envoyé, modification interdite" },
        409
      );
    }

    await patchDoc(projectId, fsToken, COLLECTION_DRAFTS, draftId, patch);
    await createAuditLog(projectId, fsToken, {
      agent: "beatrice",
      action: "modify_draft",
      targetType: COLLECTION_DRAFTS,
      targetId: draftId,
      result: "success",
      details: { fieldsModified: Object.keys(patch) },
    });

    return jsonResponse({ ok: true, draftId, fieldsUpdated: Object.keys(patch) });
  } catch (e) {
    return jsonResponse({ error: e.message }, 500);
  }
}

export const config = {
  path: "/api/beatrice-update-draft",
};
