rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Dossier temporaire pour l'analyse de gros PDFs — accès public en lecture/écriture
    // Les fichiers sont supprimés automatiquement après l'analyse
    match /temp-analysis/{allPaths=**} {
      allow read, write: if true;
    }
    // Uploads clients via lien tokenisé (portail de dépôt)
    match /dossiers/{dossierID}/uploads/{filename} {
      allow write: if true;  // validation du token faite côté client (Firestore lookup)
      allow read: if request.auth != null;
    }
    // Tout le reste requiert authentification
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
