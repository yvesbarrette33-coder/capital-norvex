export default async (req) => {
  if (req.method !== "POST") return new Response("Method Not Allowed", { status: 405 });
  if (!checkInternalSecret(req)) return unauthorized();

  const results = [];

  // 1) Créer les dossiers test
  for (const dossier of TEST_DOSSIERS) {
    try {
      await firestoreCreate("dossiers", dossier.data, dossier.id);
      results.push({ type: "dossier", id: dossier.id, ok: true });
    } catch (e) {
      results.push({ type: "dossier", id: dossier.id, ok: false, error: e.message });
    }
  }

  // 2) Créer les sessions pré-validées pour Yves et Suzanne (1 an)
  const oneYearFromNow = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000);
  for (const session of PRE_VALIDATED_SESSIONS) {
    try {
      const docId = session.phone.replace(/^\+/, "p");
      await firestoreCreate(
        "norahSessions",
        {
          phone: session.phone,
          role: session.role,
          display_name: session.display_name,
          verified_at: new Date(),
          expires_at: oneYearFromNow,
          pre_validated: true,
        },
        docId
      );
      results.push({ type: "session", id: session.phone, ok: true });
    } catch (e) {
      results.push({ type: "session", id: session.phone, ok: false, error: e.message });
    }
  }

  const allOk = results.every((r) => r.ok);
  return json({ ok: allOk, results }, allOk ? 200 : 500);
};
